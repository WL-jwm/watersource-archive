# watersource-archive Nginx 配置示例
# 将此配置放入 /etc/nginx/conf.d/ 或 /etc/nginx/sites-available/
# 适配后替换为实际域名和路径

server {
    listen 80;
    server_name your-domain.com;  # 替换为实际域名或IP

    # 水源地平台 - 部署在 /watersource/ 子路径
    location /watersource/ {
        alias /var/www/watersource-archive/dist/;
        index index.html;
        try_files $uri $uri/ /watersource/index.html;

        # 静态资源缓存（带hash文件名，长期缓存）
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }

        # 禁止访问隐藏文件
        location ~ /\. {
            deny all;
        }
    }

    # Gzip压缩
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml;
    gzip_min_length 1024;
    gzip_vary on;
}

